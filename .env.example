FEDAPAY_PUBLIC_KEY="pk_sandbox_..."
FEDAPAY_WEBHOOK_SECRET="whsec_..."
RESEND_API_KEY="re_..."
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
NEXT_PUBLIC_SITE_URL="https://sermahub.org"
