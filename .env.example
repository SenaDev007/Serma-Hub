DATABASE_URL="postgresql://user:password@localhost:5432/serma_hub?schema=public"

# Obligatoire pour NextAuth. Générer avec: openssl rand -base64 32
# Si absent en dev, un secret par défaut est utilisé (évite l'erreur "no matching decryption secret" au redémarrage).
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
