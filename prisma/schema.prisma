generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Filiere {
  id          Int          @id @default(autoincrement())
  nom         String
  description String
  iconSlug    String       @map("icone_slug")
  dureeMois   Int          @map("duree_mois")
  actif       Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  apprenants  Apprenant[]

  @@map("filieres")
}

model Apprenant {
  id               Int        @id @default(autoincrement())
  nom              String
  prenom           String
  email            String?
  telephone        String
  filiereId        Int        @map("filiere_id")
  filiere          Filiere    @relation(fields: [filiereId], references: [id])
  statut           String     @default("en_attente")
  dateInscription  DateTime   @map("date_inscription") @default(now())
  createdAt        DateTime   @default(now()) @map("created_at")
  paiements        Paiement[]

  @@map("apprenants")
}

model Paiement {
  id           Int       @id @default(autoincrement())
  apprenantId  Int       @map("apprenant_id")
  apprenant    Apprenant @relation(fields: [apprenantId], references: [id])
  montant      Int
  datePaiement DateTime  @map("date_paiement") @default(now())
  methode      String    @default("mobile_money")
  statut       String    @default("paye")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("paiements")
}

model Message {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String?
  telephone String?
  sujet     String?
  contenu   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Stat {
  id        Int      @id @default(autoincrement())
  cle       String   @unique
  valeur    String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stats")
}

model Partenaire {
  id       Int     @id @default(autoincrement())
  nom      String
  logoUrl  String? @map("logo_url")
  siteUrl  String? @map("site_url")
  actif    Boolean @default(true)

  @@map("partenaires")
}

model MembreEquipe {
  id          Int    @id @default(autoincrement())
  prenom      String
  nom         String
  role        String
  description String
  initiales   String
  actif       Boolean @default(true)

  @@map("equipe")
}
